{
  "expo": {
    "name": "STEADY",
    "slug": "steady",
    "scheme": "steady",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.steadyapp.android",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#E6F4FE"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "STEADY uses your photo library to log meals from existing photos.",
          "cameraPermission": "STEADY uses your camera to photograph meals for AI nutrition logging."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7f4eb847-e9f4-43b5-a83f-7a91b92dae08"
      }
    },
    "owner": "me-shivamo"
  }
}
